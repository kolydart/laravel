{
    "name": "kolydart/laravel",
    "description": "A collection of laravel helper classes",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "autoload": {
        "psr-4": {
            "Kolydart\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kolydart\\Laravel\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Tassos Kolydas"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/translation": "^10.0|^11.0|^12.0",
        "mockery/mockery": "^1.6",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/events": "^10.0|^11.0|^12.0",
        "laravel/framework": "^10.0|^11.0|^12.0"
    },
    "suggest": {
        "doctrine/dbal": "Required to generate ERDs."
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kolydart\\Laravel\\Providers\\DbSeedProtectionServiceProvider",
                "Kolydart\\Laravel\\Providers\\ComponentsServiceProvider",
                "Kolydart\\Laravel\\Providers\\KolydartServiceProvider",
                "Kolydart\\Laravel\\Providers\\OrderedPivotServiceProvider",
                "Kolydart\\Laravel\\Providers\\RoleServiceProvider"
            ]
        }
    }
}
